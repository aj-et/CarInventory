FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy all projects
COPY CarInventory.Domain/ CarInventory.Domain/
COPY CarInventory.Infrastructure/ CarInventory.Infrastructure/
COPY CarInventory.API/ CarInventory.API/

# Restore and publish
WORKDIR /src/CarInventory.API
RUN dotnet restore
RUN dotnet publish -c Release -o /app/out

# Runtime image
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/out .

EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

ENTRYPOINT ["dotnet", "CarInventory.API.dll"]